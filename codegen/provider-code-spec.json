{
	"datasources": [
		{
			"name": "account",
			"schema": {
				"attributes": [
					{
						"name": "cust_address",
						"string": {
							"computed_optional_required": "computed",
							"description": "Postal address."
						}
					},
					{
						"name": "cust_billing_email",
						"string": {
							"computed_optional_required": "computed",
							"description": "Billing email."
						}
					},
					{
						"name": "cust_city",
						"string": {
							"computed_optional_required": "computed",
							"description": "City."
						}
					},
					{
						"name": "cust_company_no",
						"string": {
							"computed_optional_required": "computed",
							"description": "Organization/company number."
						}
					},
					{
						"name": "cust_country",
						"string": {
							"computed_optional_required": "computed",
							"description": "Country."
						}
					},
					{
						"name": "cust_email",
						"string": {
							"computed_optional_required": "computed",
							"description": "Primary contact email."
						}
					},
					{
						"name": "cust_id",
						"string": {
							"computed_optional_required": "computed",
							"description": "Customer id."
						}
					},
					{
						"name": "cust_name",
						"string": {
							"computed_optional_required": "computed",
							"description": "Customer (company or person) name."
						}
					},
					{
						"name": "cust_phone",
						"string": {
							"computed_optional_required": "computed",
							"description": "Phone number."
						}
					},
					{
						"name": "cust_zipcode",
						"string": {
							"computed_optional_required": "computed",
							"description": "Postal/ZIP code."
						}
					}
				]
			}
		},
		{
			"name": "dns_zones",
			"schema": {
				"attributes": [
					{
						"name": "zones",
						"list_nested": {
							"computed_optional_required": "computed",
							"nested_object": {
								"attributes": [
									{
										"name": "external_dns",
										"bool": {
											"computed_optional_required": "computed",
											"description": "Whether the zone is served by external nameservers."
										}
									},
									{
										"name": "zone_active",
										"bool": {
											"computed_optional_required": "computed",
											"description": "Whether the zone is active."
										}
									},
									{
										"name": "zone_id",
										"string": {
											"computed_optional_required": "computed",
											"description": "Zone id."
										}
									},
									{
										"name": "zone_name",
										"string": {
											"computed_optional_required": "computed",
											"description": "Domain name."
										}
									},
									{
										"name": "zone_protected",
										"bool": {
											"computed_optional_required": "computed",
											"description": "Whether the zone is protected against deletion."
										}
									},
									{
										"name": "zone_type",
										"string": {
											"computed_optional_required": "computed",
											"description": "Zone type (NATIVE, MASTER, or SLAVE)."
										}
									}
								]
							},
							"description": "DNS zones on the account."
						}
					}
				]
			}
		},
		{
			"name": "ssh_keys",
			"schema": {
				"attributes": [
					{
						"name": "ssh_keys",
						"list_nested": {
							"computed_optional_required": "computed",
							"nested_object": {
								"attributes": [
									{
										"name": "key_added",
										"string": {
											"computed_optional_required": "computed",
											"description": "When the key was added (Unix timestamp, string-encoded)."
										}
									},
									{
										"name": "key_data",
										"string": {
											"computed_optional_required": "computed",
											"description": "The OpenSSH public key material."
										}
									},
									{
										"name": "key_id",
										"string": {
											"computed_optional_required": "computed",
											"description": "SSH key id."
										}
									},
									{
										"name": "key_name",
										"string": {
											"computed_optional_required": "computed",
											"description": "SSH key name."
										}
									}
								]
							},
							"description": "SSH public keys registered on the account."
						}
					}
				]
			}
		}
	],
	"provider": {
		"name": "gigahost"
	},
	"resources": [
		{
			"name": "dns_record",
			"schema": {
				"attributes": [
					{
						"name": "record_name",
						"string": {
							"computed_optional_required": "computed_optional",
							"description": "Record name (host); defaults to \"@\"."
						}
					},
					{
						"name": "record_priority",
						"int64": {
							"computed_optional_required": "computed_optional",
							"description": "Priority (used by MX and SRV records)."
						}
					},
					{
						"name": "record_ttl",
						"int64": {
							"computed_optional_required": "computed_optional",
							"description": "Time to live, in seconds; defaults to 3600."
						}
					},
					{
						"name": "record_type",
						"string": {
							"computed_optional_required": "computed_optional",
							"description": "Record type; defaults to \"A\"."
						}
					},
					{
						"name": "record_value",
						"string": {
							"computed_optional_required": "required",
							"description": "Record value (content)."
						}
					},
					{
						"name": "record_id",
						"string": {
							"computed_optional_required": "computed",
							"description": "Record id."
						}
					},
					{
						"name": "zone_id",
						"string": {
							"computed_optional_required": "computed_optional"
						}
					}
				]
			}
		},
		{
			"name": "dns_zone",
			"schema": {
				"attributes": [
					{
						"name": "zone_name",
						"string": {
							"computed_optional_required": "required",
							"description": "Domain name."
						}
					},
					{
						"name": "zone_type",
						"string": {
							"computed_optional_required": "computed_optional",
							"description": "Zone type (NATIVE, MASTER, or SLAVE)."
						}
					},
					{
						"name": "external_dns",
						"bool": {
							"computed_optional_required": "computed",
							"description": "Whether the zone is served by external nameservers."
						}
					},
					{
						"name": "zone_active",
						"bool": {
							"computed_optional_required": "computed",
							"description": "Whether the zone is active."
						}
					},
					{
						"name": "zone_id",
						"string": {
							"computed_optional_required": "computed",
							"description": "Zone id."
						}
					},
					{
						"name": "zone_protected",
						"bool": {
							"computed_optional_required": "computed",
							"description": "Whether the zone is protected against deletion."
						}
					}
				]
			}
		}
	],
	"version": "0.1"
}